# ============================================================
# ARQUIVO DE EXEMPLO - Configuração do Ambiente
# ============================================================
# Copie este arquivo para .env e edite com seus dados:
#   cp .env_example .env
# Ou pelo File Manager: duplique e renomeie para .env
# ============================================================

# --- Banco de Dados MySQL ---
# Hostinger: mysql.hostinger.com
# Local:     localhost
DB_HOST=localhost

# Porta padrão do MySQL
DB_PORT=3306

# Nome do banco de dados
# Hostinger: u123456789_plataforma
DB_NAME=plataforma_jogos

# Usuário do MySQL
# Hostinger: u123456789_root
DB_USER=root

# Senha do MySQL (deixe vazio para XAMPP local)
DB_PASS=

# --- Painel Administrativo ---
# Senha para acessar /admin/
ADMIN_PASS=admin123